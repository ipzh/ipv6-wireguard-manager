#!/bin/bash
# 导入公共函数库
if [[ -f "$(dirname "${BASH_SOURCE[0]}")/common_functions.sh" ]]; then
    source "$(dirname "${BASH_SOURCE[0]}")/common_functions.sh"
fi

# 错误处理模块
# 提供统一的错误处理、日志记录和异常恢复机制

# 错误代码定义
declare -A ERROR_CODES=(
    ["SUCCESS"]=0
    ["GENERAL_ERROR"]=1
    ["PERMISSION_DENIED"]=2
    ["FILE_NOT_FOUND"]=3
    ["INVALID_CONFIG"]=4
    ["SERVICE_ERROR"]=5
    ["NETWORK_ERROR"]=6
    ["DEPENDENCY_ERROR"]=7
    ["INSTALLATION_ERROR"]=8
    ["CONFIGURATION_ERROR"]=9
    ["VALIDATION_ERROR"]=10
    ["TIMEOUT_ERROR"]=11
    ["RESOURCE_ERROR"]=12
    ["SECURITY_ERROR"]=13
    ["COMPATIBILITY_ERROR"]=14
    ["BACKUP_ERROR"]=15
    ["RESTORE_ERROR"]=16
    ["UPDATE_ERROR"]=17
    ["MONITORING_ERROR"]=18
    ["FIREWALL_ERROR"]=19
    ["BGP_ERROR"]=20
    ["WIREGUARD_ERROR"]=21
    ["CLIENT_ERROR"]=22
    ["WEB_ERROR"]=23
    ["BATCH_ERROR"]=24
    ["DIAGNOSTIC_ERROR"]=25
)

# 错误严重级别
declare -A ERROR_SEVERITY=(
    ["CRITICAL"]=1
    ["HIGH"]=2
    ["MEDIUM"]=3
    ["LOW"]=4
    ["INFO"]=5
)

# 错误统计
declare -A ERROR_STATS
ERROR_STATS["total"]=0
ERROR_STATS["critical"]=0
ERROR_STATS["high"]=0
ERROR_STATS["medium"]=0
ERROR_STATS["low"]=0
ERROR_STATS["info"]=0

# 错误历史记录
ERROR_HISTORY=()

# 错误处理配置
ERROR_CONFIG=(
    "LOG_ERRORS=true"
    "SEND_ALERTS=false"
    "AUTO_RECOVERY=true"
    "MAX_RETRIES=3"
    "RETRY_DELAY=5"
    "ERROR_THRESHOLD=10"
    "CLEANUP_ON_ERROR=true"
)

# 初始化错误处理
init_error_handling() {
    log_info "初始化错误处理系统..."
    
    # 设置错误陷阱
    trap 'handle_script_error $? $LINENO "${BASH_COMMAND}"' ERR
    trap 'handle_script_exit' EXIT
    
    # 加载错误配置
    load_error_config
    
    log_info "错误处理系统初始化完成"
}

# 加载错误配置
load_error_config() {
    local config_file="${CONFIG_DIR}/error_handling.conf"
    
    if [[ -f "$config_file" ]]; then
        source "$config_file"
        log_debug "已加载错误处理配置"
    else
        # 创建默认配置
        create_default_error_config
    fi
}

# 创建默认错误配置
create_default_error_config() {
    local config_file="${CONFIG_DIR}/error_handling.conf"
    
    cat > "$config_file" << EOF
# 错误处理配置文件
LOG_ERRORS=true
SEND_ALERTS=false
AUTO_RECOVERY=true
MAX_RETRIES=3
RETRY_DELAY=5
ERROR_THRESHOLD=10
CLEANUP_ON_ERROR=true
ALERT_EMAIL=""
ALERT_WEBHOOK=""
ERROR_LOG_FILE="/var/log/ipv6-wireguard-errors.log"
EOF
    
    log_info "已创建默认错误处理配置: $config_file"
}

# 处理脚本错误
handle_script_error() {
    local exit_code="$1"
    local line_number="$2"
    local command="$3"
    local timestamp=$(get_timestamp)
    
    # 记录错误统计
    ERROR_STATS["total"]=$((ERROR_STATS["total"] + 1))
    
    # 确定错误严重级别
    local severity="MEDIUM"
    if [[ $exit_code -eq 1 ]]; then
        severity="HIGH"
    elif [[ $exit_code -gt 10 ]]; then
        severity="CRITICAL"
    fi
    
    ERROR_STATS["$(to_lower "$severity")"]=$((ERROR_STATS["$(to_lower "$severity")"] + 1))
    
    # 创建错误记录
    local error_record="{
        \"timestamp\": \"$timestamp\",
        \"exit_code\": $exit_code,
        \"line_number\": $line_number,
        \"command\": \"$command\",
        \"severity\": \"$severity\",
        \"script\": \"${BASH_SOURCE[1]:-unknown}\",
        \"function\": \"${FUNCNAME[1]:-unknown}\"
    }"
    
    # 添加到历史记录
    ERROR_HISTORY+=("$error_record")
    
    # 记录错误日志
    if [[ "${LOG_ERRORS:-true}" == "true" ]]; then
        log_error "脚本错误: 退出码=$exit_code, 行号=$line_number, 命令='$command'"
    fi
    
    # 发送告警
    if [[ "${SEND_ALERTS:-false}" == "true" ]]; then
        send_error_alert "$severity" "$exit_code" "$line_number" "$command"
    fi
    
    # 自动恢复
    if [[ "${AUTO_RECOVERY:-true}" == "true" ]]; then
        attempt_auto_recovery "$exit_code" "$command"
    fi
    
    # 清理资源
    if [[ "${CLEANUP_ON_ERROR:-true}" == "true" ]]; then
        cleanup_on_error
    fi
}

# 处理脚本退出
handle_script_exit() {
    local exit_code="$?"
    
    if [[ $exit_code -ne 0 ]]; then
        log_error "脚本异常退出，退出码: $exit_code"
        
        # 生成错误报告
        generate_error_report
        
        # 检查错误阈值
        if [[ ${ERROR_STATS["total"]} -gt ${ERROR_THRESHOLD:-10} ]]; then
            log_critical "错误数量超过阈值 (${ERROR_STATS["total"]}/${ERROR_THRESHOLD})"
        fi
    else
        log_info "脚本正常退出"
    fi
}

# 发送错误告警
send_error_alert() {
    local severity="$1"
    local exit_code="$2"
    local line_number="$3"
    local command="$4"
    
    local message="IPv6 WireGuard Manager 错误告警
严重级别: $severity
退出码: $exit_code
行号: $line_number
命令: $command
时间: $(get_timestamp)
主机: $(hostname)
用户: $(whoami)"
    
    # 邮件告警
    if [[ -n "${ALERT_EMAIL:-}" ]]; then
        echo "$message" | mail -s "IPv6 WireGuard Manager 错误告警" "${ALERT_EMAIL}"
    fi
    
    # Webhook告警
    if [[ -n "${ALERT_WEBHOOK:-}" ]]; then
        local payload="{
            \"text\": \"IPv6 WireGuard Manager 错误告警\",
            \"attachments\": [{
                \"color\": \"danger\",
                \"fields\": [
                    {\"title\": \"严重级别\", \"value\": \"$severity\", \"short\": true},
                    {\"title\": \"退出码\", \"value\": \"$exit_code\", \"short\": true},
                    {\"title\": \"行号\", \"value\": \"$line_number\", \"short\": true},
                    {\"title\": \"命令\", \"value\": \"$command\", \"short\": false},
                    {\"title\": \"时间\", \"value\": \"$(get_timestamp)\", \"short\": true},
                    {\"title\": \"主机\", \"value\": \"$(hostname)\", \"short\": true}
                ]
            }]
        }"
        
        curl -X POST -H 'Content-type: application/json' \
             --data "$payload" "${ALERT_WEBHOOK}" 2>/dev/null || true
    fi
}

# 尝试自动恢复
attempt_auto_recovery() {
    local exit_code="$1"
    local command="$2"
    
    log_info "尝试自动恢复..."
    
    case $exit_code in
        2) # 权限错误
            log_warn "检测到权限错误，尝试修复权限"
            fix_permissions
            ;;
        3) # 文件不存在
            log_warn "检测到文件不存在错误，尝试创建文件"
            create_missing_files
            ;;
        5) # 服务错误
            log_warn "检测到服务错误，尝试重启服务"
            restart_failed_services
            ;;
        6) # 网络错误
            log_warn "检测到网络错误，尝试网络诊断"
            diagnose_network_issues
            ;;
        7) # 依赖错误
            log_warn "检测到依赖错误，尝试安装依赖"
            install_missing_dependencies
            ;;
        *)
            log_warn "未知错误类型，跳过自动恢复"
            ;;
    esac
}

# 清理错误资源
cleanup_on_error() {
    log_debug "清理错误资源..."
    
    # 清理临时文件
    if [[ -n "${TEMP_FILES:-}" ]]; then
        for temp_file in "${TEMP_FILES[@]}"; do
            if [[ -f "$temp_file" ]]; then
                rm -f "$temp_file"
                log_debug "已清理临时文件: $temp_file"
            fi
        done
    fi
    
    # 清理锁文件
    local lock_files=(
        "/var/lock/ipv6-wireguard-manager.lock"
        "/tmp/ipv6-wireguard-*.lock"
    )
    
    for lock_pattern in "${lock_files[@]}"; do
        for lock_file in $lock_pattern; do
            if [[ -f "$lock_file" ]]; then
                rm -f "$lock_file"
                log_debug "已清理锁文件: $lock_file"
            fi
        done
    done
}

# 生成错误报告
generate_error_report() {
    local report_file="/tmp/ipv6-wireguard-error-report-$(date +%Y%m%d_%H%M%S).txt"
    
    cat > "$report_file" << EOF
IPv6 WireGuard Manager 错误报告
生成时间: $(get_timestamp)
主机: $(hostname)
用户: $(whoami)
脚本: $0
参数: $*

错误统计:
  总计: ${ERROR_STATS["total"]}
  严重: ${ERROR_STATS["critical"]}
  高: ${ERROR_STATS["high"]}
  中: ${ERROR_STATS["medium"]}
  低: ${ERROR_STATS["low"]}
  信息: ${ERROR_STATS["info"]}

系统信息:
  操作系统: $OS_TYPE $OS_VERSION
  架构: $ARCH
  包管理器: $PACKAGE_MANAGER
  内存使用: $(get_memory_usage)%
  磁盘使用: $(get_disk_usage)%
  系统负载: $(get_system_load)

最近错误:
EOF
    
    # 添加最近的错误记录
    local count=0
    for error_record in "${ERROR_HISTORY[@]}"; do
        if [[ $count -lt 10 ]]; then
            echo "  $error_record" >> "$report_file"
            ((count++))
        fi
    done
    
    log_info "错误报告已生成: $report_file"
    echo "$report_file"
}

# 错误恢复函数
fix_permissions() {
    log_info "修复权限问题..."
    
    # 修复WireGuard配置目录权限
    if [[ -d "/etc/wireguard" ]]; then
        chmod 700 /etc/wireguard
        chown root:root /etc/wireguard
    fi
    
    # 修复日志文件权限
    if [[ -f "$LOG_FILE" ]]; then
        chmod 644 "$LOG_FILE"
        chown root:root "$LOG_FILE"
    fi
    
    # 修复配置文件权限
    if [[ -f "$CONFIG_FILE" ]]; then
        chmod 600 "$CONFIG_FILE"
        chown root:root "$CONFIG_FILE"
    fi
}

create_missing_files() {
    log_info "创建缺失的文件..."
    
    # 创建必要的目录
    mkdir -p "$CONFIG_DIR" "$MODULES_DIR" "$SCRIPTS_DIR"
    mkdir -p "$(dirname "$LOG_FILE")"
    mkdir -p "/etc/wireguard/clients"
    
    # 创建默认配置文件
    if [[ ! -f "$CONFIG_FILE" ]]; then
        init_config
    fi
}

restart_failed_services() {
    log_info "重启失败的服务..."
    
    local services=("wireguard" "bird" "nginx" "apache2")
    
    for service in "${services[@]}"; do
        if is_service_running "$service"; then
            log_debug "服务 $service 正在运行"
        else
            log_warn "服务 $service 未运行，尝试启动"
            start_service "$service" || log_error "无法启动服务: $service"
        fi
    done
}

diagnose_network_issues() {
    log_info "诊断网络问题..."
    
    # 检查网络连接
    if ! ping -c 1 8.8.8.8 &>/dev/null; then
        log_error "无法连接到互联网"
        return 1
    fi
    
    # 检查DNS解析
    if ! nslookup google.com &>/dev/null; then
        log_error "DNS解析失败"
        return 1
    fi
    
    # 检查端口占用
    local port="${WIREGUARD_PORT:-51820}"
    if netstat -tuln | grep -q ":$port "; then
        log_warn "端口 $port 已被占用"
    fi
}

install_missing_dependencies() {
    log_info "安装缺失的依赖..."
    
    local dependencies=("wireguard" "bird" "curl" "wget" "jq")
    
    for dep in "${dependencies[@]}"; do
        if ! command -v "$dep" &>/dev/null; then
            log_warn "安装依赖: $dep"
            install_package "$dep" || log_error "无法安装依赖: $dep"
        fi
    done
}

# 错误重试机制
retry_with_backoff() {
    local max_retries="${MAX_RETRIES:-3}"
    local delay="${RETRY_DELAY:-5}"
    local command="$*"
    local attempt=1
    
    while [[ $attempt -le $max_retries ]]; do
        log_info "执行命令 (尝试 $attempt/$max_retries): $command"
        
        if eval "$command"; then
            log_info "命令执行成功"
            return 0
        else
            local exit_code=$?
            log_warn "命令执行失败 (退出码: $exit_code)"
            
            if [[ $attempt -lt $max_retries ]]; then
                log_info "等待 $delay 秒后重试..."
                sleep $delay
                delay=$((delay * 2))  # 指数退避
            fi
        fi
        
        ((attempt++))
    done
    
    log_error "命令在 $max_retries 次尝试后仍然失败"
    return 1
}

# 错误验证
validate_error_handling() {
    log_info "验证错误处理系统..."
    
    local errors=0
    
    # 检查错误代码定义
    for error_name in "${!ERROR_CODES[@]}"; do
        if [[ -z "${ERROR_CODES[$error_name]}" ]]; then
            log_error "错误代码未定义: $error_name"
            ((errors++))
        fi
    done
    
    # 检查错误严重级别
    for severity in "${!ERROR_SEVERITY[@]}"; do
        if [[ -z "${ERROR_SEVERITY[$severity]}" ]]; then
            log_error "错误严重级别未定义: $severity"
            ((errors++))
        fi
    done
    
    # 检查配置文件
    if [[ ! -f "${CONFIG_DIR}/error_handling.conf" ]]; then
        log_warn "错误处理配置文件不存在"
        create_default_error_config
    fi
    
    if [[ $errors -eq 0 ]]; then
        log_info "错误处理系统验证通过"
        return 0
    else
        log_error "错误处理系统验证失败，发现 $errors 个问题"
        return 1
    fi
}

# 获取错误统计
get_error_stats() {
    echo "错误统计信息:"
    echo "  总计: ${ERROR_STATS["total"]}"
    echo "  严重: ${ERROR_STATS["critical"]}"
    echo "  高: ${ERROR_STATS["high"]}"
    echo "  中: ${ERROR_STATS["medium"]}"
    echo "  低: ${ERROR_STATS["low"]}"
    echo "  信息: ${ERROR_STATS["info"]}"
}

# 清除错误历史
clear_error_history() {
    ERROR_HISTORY=()
    for key in "${!ERROR_STATS[@]}"; do
        ERROR_STATS[$key]=0
    done
    log_info "错误历史已清除"
}

# 导出函数
export -f init_error_handling load_error_config create_default_error_config
export -f handle_script_error handle_script_exit send_error_alert
export -f attempt_auto_recovery cleanup_on_error generate_error_report
export -f fix_permissions create_missing_files restart_failed_services
export -f diagnose_network_issues install_missing_dependencies
export -f retry_with_backoff validate_error_handling get_error_stats clear_error_history

#!/bin/bash

# 增强Windows系统支持模块
# 提供全面的Windows环境检测、路径适配和命令兼容性功能

# =============================================================================
# Windows支持配置
# =============================================================================

# Windows环境检测
declare -g IPV6WGM_WINDOWS_ENV=""
declare -g IPV6WGM_WSL_ENV=false
declare -g IPV6WGM_MSYS_ENV=false
declare -g IPV6WGM_CYGWIN_ENV=false
declare -g IPV6WGM_POWERSHELL_ENV=false

# Windows路径配置
declare -g IPV6WGM_WINDOWS_DRIVE=""
declare -g IPV6WGM_WINDOWS_PATH=""
declare -g IPV6WGM_UNIX_PATH=""

# Windows命令别名
declare -A IPV6WGM_WINDOWS_ALIASES=()

# Windows兼容性设置
declare -g IPV6WGM_WINDOWS_COMPATIBILITY_MODE=true
declare -g IPV6WGM_WINDOWS_PATH_CONVERSION=true
declare -g IPV6WGM_WINDOWS_COMMAND_ALIASING=true

# =============================================================================
# Windows支持函数
# =============================================================================

# 初始化Windows支持
init_windows_support() {
    log_info "初始化Windows系统支持..."
    
    # 检测Windows环境
    detect_windows_environment
    
    # 设置Windows路径
    setup_windows_paths
    
    # 配置命令别名
    setup_windows_aliases
    
    # 验证Windows兼容性
    verify_windows_compatibility
    
    log_success "Windows系统支持初始化完成"
    return 0
}

# 检测Windows环境
detect_windows_environment() {
    log_info "检测Windows环境..."
    
    # 检测WSL环境
    if [[ -f /proc/version ]] && grep -qi microsoft /proc/version; then
        IPV6WGM_WSL_ENV=true
        IPV6WGM_WINDOWS_ENV="WSL"
        log_info "检测到WSL环境"
    fi
    
    # 检测MSYS环境
    if [[ -n "$MSYSTEM" ]] || [[ -n "$MSYS2_ROOT" ]]; then
        IPV6WGM_MSYS_ENV=true
        IPV6WGM_WINDOWS_ENV="MSYS"
        log_info "检测到MSYS环境"
    fi
    
    # 检测Cygwin环境
    if [[ -n "$CYGWIN" ]] || command -v cygpath >/dev/null 2>&1; then
        IPV6WGM_CYGWIN_ENV=true
        IPV6WGM_WINDOWS_ENV="Cygwin"
        log_info "检测到Cygwin环境"
    fi
    
    # 检测PowerShell环境
    if [[ -n "$PSVersionTable" ]] || command -v pwsh >/dev/null 2>&1; then
        IPV6WGM_POWERSHELL_ENV=true
        IPV6WGM_WINDOWS_ENV="PowerShell"
        log_info "检测到PowerShell环境"
    fi
    
    # 检测原生Windows环境
    if [[ -z "$IPV6WGM_WINDOWS_ENV" ]] && [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]]; then
        IPV6WGM_WINDOWS_ENV="Native"
        log_info "检测到原生Windows环境"
    fi
    
    log_info "Windows环境类型: $IPV6WGM_WINDOWS_ENV"
}

# 设置Windows路径
setup_windows_paths() {
    log_info "设置Windows路径配置..."
    
    # 检测Windows驱动器
    if [[ "$IPV6WGM_WSL_ENV" == "true" ]]; then
        # WSL环境
        IPV6WGM_WINDOWS_DRIVE="/mnt/c"
        IPV6WGM_WINDOWS_PATH="/mnt/c/Windows/System32"
        IPV6WGM_UNIX_PATH="/usr/bin"
    elif [[ "$IPV6WGM_MSYS_ENV" == "true" ]]; then
        # MSYS环境
        IPV6WGM_WINDOWS_DRIVE="C:"
        IPV6WGM_WINDOWS_PATH="/c/Windows/System32"
        IPV6WGM_UNIX_PATH="/usr/bin"
    elif [[ "$IPV6WGM_CYGWIN_ENV" == "true" ]]; then
        # Cygwin环境
        IPV6WGM_WINDOWS_DRIVE="C:"
        IPV6WGM_WINDOWS_PATH="/cygdrive/c/Windows/System32"
        IPV6WGM_UNIX_PATH="/usr/bin"
    else
        # 其他环境
        IPV6WGM_WINDOWS_DRIVE="C:"
        IPV6WGM_WINDOWS_PATH="C:\\Windows\\System32"
        IPV6WGM_UNIX_PATH="/usr/bin"
    fi
    
    log_debug "Windows驱动器: $IPV6WGM_WINDOWS_DRIVE"
    log_debug "Windows路径: $IPV6WGM_WINDOWS_PATH"
    log_debug "Unix路径: $IPV6WGM_UNIX_PATH"
}

# 配置命令别名
setup_windows_aliases() {
    log_info "配置Windows命令别名..."
    
    # 基础命令别名
    IPV6WGM_WINDOWS_ALIASES["ip"]="ipconfig"
    IPV6WGM_WINDOWS_ALIASES["free"]="wmic memorychip get capacity"
    IPV6WGM_WINDOWS_ALIASES["ps"]="tasklist"
    IPV6WGM_WINDOWS_ALIASES["kill"]="taskkill"
    IPV6WGM_WINDOWS_ALIASES["df"]="wmic logicaldisk get size,freespace,caption"
    IPV6WGM_WINDOWS_ALIASES["du"]="dir /s"
    IPV6WGM_WINDOWS_ALIASES["grep"]="findstr"
    IPV6WGM_WINDOWS_ALIASES["sed"]="powershell -Command"
    IPV6WGM_WINDOWS_ALIASES["awk"]="powershell -Command"
    IPV6WGM_WINDOWS_ALIASES["curl"]="curl.exe"
    IPV6WGM_WINDOWS_ALIASES["wget"]="wget.exe"
    IPV6WGM_WINDOWS_ALIASES["tar"]="tar.exe"
    IPV6WGM_WINDOWS_ALIASES["gzip"]="gzip.exe"
    IPV6WGM_WINDOWS_ALIASES["gunzip"]="gunzip.exe"
    
    # 网络命令别名
    IPV6WGM_WINDOWS_ALIASES["netstat"]="netstat.exe"
    IPV6WGM_WINDOWS_ALIASES["ss"]="netstat.exe"
    IPV6WGM_WINDOWS_ALIASES["lsof"]="netstat.exe"
    IPV6WGM_WINDOWS_ALIASES["tcpdump"]="netsh trace"
    IPV6WGM_WINDOWS_ALIASES["ping"]="ping.exe"
    IPV6WGM_WINDOWS_ALIASES["traceroute"]="tracert.exe"
    IPV6WGM_WINDOWS_ALIASES["nslookup"]="nslookup.exe"
    IPV6WGM_WINDOWS_ALIASES["dig"]="nslookup.exe"
    
    # 系统命令别名
    IPV6WGM_WINDOWS_ALIASES["uptime"]="wmic os get lastbootuptime"
    IPV6WGM_WINDOWS_ALIASES["whoami"]="whoami.exe"
    IPV6WGM_WINDOWS_ALIASES["id"]="whoami.exe"
    IPV6WGM_WINDOWS_ALIASES["groups"]="net user"
    IPV6WGM_WINDOWS_ALIASES["passwd"]="net user"
    IPV6WGM_WINDOWS_ALIASES["chmod"]="icacls"
    IPV6WGM_WINDOWS_ALIASES["chown"]="icacls"
    IPV6WGM_WINDOWS_ALIASES["ln"]="mklink"
    IPV6WGM_WINDOWS_ALIASES["mount"]="mountvol"
    IPV6WGM_WINDOWS_ALIASES["umount"]="mountvol"
    
    log_debug "已配置 ${#IPV6WGM_WINDOWS_ALIASES[@]} 个命令别名"
}

# 验证Windows兼容性
verify_windows_compatibility() {
    log_info "验证Windows兼容性..."
    
    local compatibility_issues=()
    
    # 检查必要命令
    local required_commands=("curl" "wget" "tar" "gzip")
    for cmd in "${required_commands[@]}"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            local alias_cmd="${IPV6WGM_WINDOWS_ALIASES[$cmd]}"
            if [[ -n "$alias_cmd" ]] && command -v "$alias_cmd" >/dev/null 2>&1; then
                log_debug "命令 $cmd 通过别名 $alias_cmd 可用"
            else
                compatibility_issues+=("$cmd")
            fi
        fi
    done
    
    # 检查路径转换
    if [[ "$IPV6WGM_WINDOWS_PATH_CONVERSION" == "true" ]]; then
        if ! test_path_conversion; then
            compatibility_issues+=("path_conversion")
        fi
    fi
    
    # 检查权限
    if ! test_windows_permissions; then
        compatibility_issues+=("permissions")
    fi
    
    # 报告兼容性问题
    if [[ ${#compatibility_issues[@]} -gt 0 ]]; then
        log_warn "发现兼容性问题: ${compatibility_issues[*]}"
        return 1
    else
        log_success "Windows兼容性验证通过"
        return 0
    fi
}

# 测试路径转换
test_path_conversion() {
    local test_path="/tmp/test"
    local converted_path=$(convert_path "$test_path")
    
    if [[ -n "$converted_path" && "$converted_path" != "$test_path" ]]; then
        log_debug "路径转换测试通过: $test_path -> $converted_path"
        return 0
    else
        log_debug "路径转换测试失败"
        return 1
    fi
}

# 测试Windows权限
test_windows_permissions() {
    local test_file="/tmp/windows_test_$$"
    
    if touch "$test_file" 2>/dev/null; then
        rm -f "$test_file"
        log_debug "权限测试通过"
        return 0
    else
        log_debug "权限测试失败"
        return 1
    fi
}

# 转换路径格式
convert_path() {
    local path="$1"
    
    if [[ -z "$path" ]]; then
        return 1
    fi
    
    # WSL环境路径转换
    if [[ "$IPV6WGM_WSL_ENV" == "true" ]]; then
        # 将Windows路径转换为WSL路径
        if [[ "$path" =~ ^[A-Za-z]: ]]; then
            local drive_letter=$(echo "$path" | cut -c1 | tr '[:upper:]' '[:lower:]')
            local remaining_path=$(echo "$path" | cut -c3-)
            echo "/mnt/$drive_letter$remaining_path" | tr '\\' '/'
        else
            echo "$path"
        fi
    # MSYS环境路径转换
    elif [[ "$IPV6WGM_MSYS_ENV" == "true" ]]; then
        # 将Windows路径转换为MSYS路径
        if [[ "$path" =~ ^[A-Za-z]: ]]; then
            local drive_letter=$(echo "$path" | cut -c1 | tr '[:upper:]' '[:lower:]')
            local remaining_path=$(echo "$path" | cut -c3-)
            echo "/$drive_letter$remaining_path" | tr '\\' '/'
        else
            echo "$path"
        fi
    # Cygwin环境路径转换
    elif [[ "$IPV6WGM_CYGWIN_ENV" == "true" ]]; then
        # 使用cygpath进行路径转换
        if command -v cygpath >/dev/null 2>&1; then
            cygpath -u "$path" 2>/dev/null || echo "$path"
        else
            echo "$path"
        fi
    else
        echo "$path"
    fi
}

# 执行Windows兼容命令
execute_windows_command() {
    local command="$1"
    shift
    local args=("$@")
    
    # 检查是否有别名
    local alias_cmd="${IPV6WGM_WINDOWS_ALIASES[$command]}"
    if [[ -n "$alias_cmd" ]]; then
        log_debug "使用别名执行命令: $command -> $alias_cmd"
        command="$alias_cmd"
    fi
    
    # 执行命令
    if [[ "$IPV6WGM_WINDOWS_ENV" == "PowerShell" ]]; then
        # PowerShell环境
        powershell -Command "$command ${args[*]}"
    else
        # 其他环境
        "$command" "${args[@]}"
    fi
}

# 获取Windows系统信息
get_windows_system_info() {
    echo "=== Windows系统信息 ==="
    echo "环境类型: $IPV6WGM_WINDOWS_ENV"
    echo "WSL环境: $([ "$IPV6WGM_WSL_ENV" == "true" ] && echo "是" || echo "否")"
    echo "MSYS环境: $([ "$IPV6WGM_MSYS_ENV" == "true" ] && echo "是" || echo "否")"
    echo "Cygwin环境: $([ "$IPV6WGM_CYGWIN_ENV" == "true" ] && echo "是" || echo "否")"
    echo "PowerShell环境: $([ "$IPV6WGM_POWERSHELL_ENV" == "true" ] && echo "是" || echo "否")"
    echo "Windows驱动器: $IPV6WGM_WINDOWS_DRIVE"
    echo "Windows路径: $IPV6WGM_WINDOWS_PATH"
    echo "Unix路径: $IPV6WGM_UNIX_PATH"
    
    # 获取系统版本信息
    if [[ "$IPV6WGM_WSL_ENV" == "true" ]]; then
        echo "WSL版本: $(cat /proc/version 2>/dev/null | grep -o 'Microsoft.*' || echo "未知")"
    fi
    
    # 获取Windows版本
    if command -v wmic >/dev/null 2>&1; then
        local windows_version=$(wmic os get caption /value 2>/dev/null | grep "Caption" | cut -d'=' -f2)
        echo "Windows版本: $windows_version"
    fi
    
    # 获取架构信息
    local arch=$(uname -m 2>/dev/null || echo "未知")
    echo "系统架构: $arch"
    
    # 获取内存信息
    if command -v wmic >/dev/null 2>&1; then
        local total_memory=$(wmic computersystem get TotalPhysicalMemory /value 2>/dev/null | grep "TotalPhysicalMemory" | cut -d'=' -f2)
        if [[ -n "$total_memory" ]]; then
            local memory_gb=$((total_memory / 1024 / 1024 / 1024))
            echo "总内存: ${memory_gb}GB"
        fi
    fi
}

# 检查Windows特定功能
check_windows_features() {
    local features=()
    
    # 检查WSL功能
    if [[ "$IPV6WGM_WSL_ENV" == "true" ]]; then
        features+=("WSL")
    fi
    
    # 检查MSYS功能
    if [[ "$IPV6WGM_MSYS_ENV" == "true" ]]; then
        features+=("MSYS")
    fi
    
    # 检查Cygwin功能
    if [[ "$IPV6WGM_CYGWIN_ENV" == "true" ]]; then
        features+=("Cygwin")
    fi
    
    # 检查PowerShell功能
    if [[ "$IPV6WGM_POWERSHELL_ENV" == "true" ]]; then
        features+=("PowerShell")
    fi
    
    # 检查网络功能
    if command -v netsh >/dev/null 2>&1; then
        features+=("Netsh")
    fi
    
    # 检查WMI功能
    if command -v wmic >/dev/null 2>&1; then
        features+=("WMI")
    fi
    
    # 检查PowerShell Core功能
    if command -v pwsh >/dev/null 2>&1; then
        features+=("PowerShell Core")
    fi
    
    echo "可用的Windows功能: ${features[*]}"
    return 0
}

# 运行Windows兼容性检查
run_windows_compatibility_check() {
    log_info "运行Windows兼容性检查..."
    
    local checks_passed=0
    local checks_failed=0
    
    # 检查环境检测
    if detect_windows_environment; then
        ((checks_passed++))
        log_success "✓ 环境检测通过"
    else
        ((checks_failed++))
        log_error "✗ 环境检测失败"
    fi
    
    # 检查路径转换
    if test_path_conversion; then
        ((checks_passed++))
        log_success "✓ 路径转换通过"
    else
        ((checks_failed++))
        log_error "✗ 路径转换失败"
    fi
    
    # 检查权限
    if test_windows_permissions; then
        ((checks_passed++))
        log_success "✓ 权限检查通过"
    else
        ((checks_failed++))
        log_error "✗ 权限检查失败"
    fi
    
    # 检查命令别名
    local alias_count=${#IPV6WGM_WINDOWS_ALIASES[@]}
    if [[ $alias_count -gt 0 ]]; then
        ((checks_passed++))
        log_success "✓ 命令别名配置完成 ($alias_count 个)"
    else
        ((checks_failed++))
        log_error "✗ 命令别名配置失败"
    fi
    
    echo
    echo "=== Windows兼容性检查结果 ==="
    echo "通过检查: $checks_passed"
    echo "失败检查: $checks_failed"
    
    if [[ $checks_failed -eq 0 ]]; then
        log_success "所有Windows兼容性检查通过！"
        return 0
    else
        log_error "有 $checks_failed 个检查失败"
        return 1
    fi
}

# 获取Windows兼容性统计
get_windows_compatibility_statistics() {
    echo "=== Windows兼容性统计 ==="
    echo "环境类型: $IPV6WGM_WINDOWS_ENV"
    echo "兼容性模式: $([ "$IPV6WGM_WINDOWS_COMPATIBILITY_MODE" == "true" ] && echo "启用" || echo "禁用")"
    echo "路径转换: $([ "$IPV6WGM_WINDOWS_PATH_CONVERSION" == "true" ] && echo "启用" || echo "禁用")"
    echo "命令别名: $([ "$IPV6WGM_WINDOWS_COMMAND_ALIASING" == "true" ] && echo "启用" || echo "禁用")"
    echo "配置别名数: ${#IPV6WGM_WINDOWS_ALIASES[@]}"
    
    # 显示环境特定信息
    case "$IPV6WGM_WINDOWS_ENV" in
        "WSL")
            echo "WSL功能: 完全支持"
            echo "Linux兼容性: 高"
            ;;
        "MSYS")
            echo "MSYS功能: 完全支持"
            echo "Unix兼容性: 中等"
            ;;
        "Cygwin")
            echo "Cygwin功能: 完全支持"
            echo "Unix兼容性: 高"
            ;;
        "PowerShell")
            echo "PowerShell功能: 完全支持"
            echo "Windows兼容性: 高"
            ;;
        *)
            echo "环境支持: 基础支持"
            ;;
    esac
}

# 导出函数
export -f init_windows_support
export -f detect_windows_environment
export -f convert_path
export -f execute_windows_command
export -f get_windows_system_info
export -f check_windows_features
export -f run_windows_compatibility_check
export -f get_windows_compatibility_statistics

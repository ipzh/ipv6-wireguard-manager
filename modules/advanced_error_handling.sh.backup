#!/bin/bash

# 高级错误处理模块
# 提供统一的错误码系统、错误处理和恢复机制

# ================================================================
# 错误码定义
# ================================================================

# 统一的错误码定义
declare -A IPV6WGM_ERROR_CODES=(
    ["SUCCESS"]=0
    ["SYNTAX_ERROR"]=1
    ["CONFIG_ERROR"]=2
    ["DEPENDENCY_ERROR"]=3
    ["PERMISSION_ERROR"]=4
    ["NETWORK_ERROR"]=5
    ["SECURITY_ERROR"]=6
    ["WINDOWS_COMPAT_ERROR"]=7
)

# 错误严重程度定义
declare -A IPV6WGM_ERROR_SEVERITY=(
    ["INFO"]=1
    ["WARNING"]=2
    ["ERROR"]=3
    ["CRITICAL"]=4
    ["FATAL"]=5
)

# ================================================================
# 错误处理函数
# ================================================================

# 统一的错误处理函数
handle_error() {
    local error_code="$1"
    local error_message="$2"
    local error_source="$3"
    local timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    
    # 记录错误到日志文件
    if [[ -n "${IPV6WGM_LOG_FILE:-}" ]]; then
        mkdir -p "$(dirname "$IPV6WGM_LOG_FILE")" 2>/dev/null || true
        echo "[$timestamp] [ERROR] [$error_code] [$error_source] $error_message" >> "$IPV6WGM_LOG_FILE" 2>/dev/null || true
    fi
    
    # 输出到控制台
    if command -v log_error >/dev/null 2>&1; then
        log_error "$error_message (代码: $error_code, 来源: $error_source)"
    else
        echo "[ERROR] $error_message (代码: $error_code, 来源: $error_source)" >&2
    fi
    
    # 根据错误类型执行恢复策略
    case "$error_code" in
        "${IPV6WGM_ERROR_CODES[CONFIG_ERROR]}")
            if command -v log_info >/dev/null 2>&1; then
                log_info "尝试使用备用配置..."
            else
                echo "[INFO] 尝试使用备用配置..." >&2
            fi
            # 实现配置恢复逻辑
            ;;
        "${IPV6WGM_ERROR_CODES[WINDOWS_COMPAT_ERROR]}")
            if command -v log_info >/dev/null 2>&1; then
                log_info "尝试Windows兼容模式..."
            else
                echo "[INFO] 尝试Windows兼容模式..." >&2
            fi
            # 实现Windows兼容逻辑
            ;;
    esac
    
    # 确保返回码是数字
    if [[ "$error_code" =~ ^[0-9]+$ ]]; then
        return "$error_code"
    else
        return 1
    fi
}

# 执行错误恢复策略
execute_error_recovery() {
    local error_code="$1"
    local error_message="$2"
    local error_source="$3"
    
    case "$error_code" in
        "CONFIG_ERROR")
            log_info "尝试使用备用配置..."
            # 实现配置恢复逻辑
            if [[ -f "${IPV6WGM_CONFIG_DIR}/backup.conf" ]]; then
                cp "${IPV6WGM_CONFIG_DIR}/backup.conf" "${IPV6WGM_CONFIG_DIR}/manager.conf"
                log_info "已恢复备用配置"
            fi
            ;;
        "WINDOWS_COMPAT_ERROR")
            log_info "尝试Windows兼容模式..."
            # 实现Windows兼容逻辑
            if [[ -f "modules/windows_compatibility.sh" ]]; then
                source "modules/windows_compatibility.sh"
                check_windows_environment
            fi
            ;;
        "NETWORK_ERROR")
            log_info "尝试网络诊断..."
            # 实现网络诊断逻辑
            run_network_diagnosis
            ;;
        "PERMISSION_ERROR")
            log_info "尝试修复权限..."
            # 实现权限修复逻辑
            fix_permissions
            ;;
        "DEPENDENCY_ERROR")
            log_info "尝试安装缺失依赖..."
            # 实现依赖安装逻辑
            install_missing_dependencies
            ;;
        "SERVICE_ERROR")
            log_info "尝试重启服务..."
            # 实现服务重启逻辑
            restart_services
            ;;
        *)
            log_debug "无特定恢复策略: $error_code"
            ;;
    esac
}

# 安全执行命令
safe_execute() {
    local command="$1"
    local description="${2:-执行命令}"
    local allow_failure="${3:-false}"
    local timeout="${4:-30}"
    local retry_count="${5:-3}"
    
    log_debug "安全执行命令: $command"
    
    local attempt=1
    local last_error=""
    
    while [[ $attempt -le $retry_count ]]; do
        log_debug "尝试 $attempt/$retry_count: $description"
        
        # 使用timeout命令限制执行时间
        if timeout "$timeout" bash -c "$command" 2>&1; then
            log_debug "✓ 命令执行成功: $description"
            return 0
        else
            last_error="$?"
            log_warn "命令执行失败 (尝试 $attempt/$retry_count): $description (退出码: $last_error)"
            
            if [[ $attempt -lt $retry_count ]]; then
                local wait_time=$((attempt * 2))
                log_debug "等待 ${wait_time}秒后重试..."
                sleep "$wait_time"
            fi
        fi
        
        ((attempt++))
    done
    
    # 所有重试都失败了
    if [[ "$allow_failure" == "true" ]]; then
        log_warn "命令执行失败但允许继续: $description"
        return 0
    else
        handle_error "EXECUTION_ERROR" "命令执行失败: $description (退出码: $last_error)" "safe_execute" "ERROR"
        return "$last_error"
    fi
}

# 验证命令执行结果
validate_command_result() {
    local command="$1"
    local expected_output="$2"
    local description="${3:-验证命令结果}"
    
    local actual_output
    if actual_output=$(eval "$command" 2>&1); then
        if [[ "$actual_output" == "$expected_output" ]]; then
            log_debug "✓ 命令结果验证通过: $description"
            return 0
        else
            handle_error "VALIDATION_ERROR" "命令结果不匹配: $description (期望: $expected_output, 实际: $actual_output)" "validate_command_result" "ERROR"
            return 1
        fi
    else
        handle_error "EXECUTION_ERROR" "命令执行失败: $description" "validate_command_result" "ERROR"
        return 1
    fi
}

# ================================================================
# 错误恢复函数
# ================================================================

# 网络诊断
run_network_diagnosis() {
    log_info "运行网络诊断..."
    
    # 检查网络接口
    if ! ip link show >/dev/null 2>&1; then
        handle_error "NETWORK_ERROR" "无法获取网络接口信息" "network_diagnosis" "WARNING"
    fi
    
    # 检查路由表
    if ! ip route show >/dev/null 2>&1; then
        handle_error "NETWORK_ERROR" "无法获取路由表信息" "network_diagnosis" "WARNING"
    fi
    
    # 检查DNS解析
    if ! nslookup google.com >/dev/null 2>&1; then
        handle_error "NETWORK_ERROR" "DNS解析失败" "network_diagnosis" "WARNING"
    fi
    
    # 检查外网连接
    if ! ping -c 1 8.8.8.8 >/dev/null 2>&1; then
        handle_error "NETWORK_ERROR" "外网连接失败" "network_diagnosis" "WARNING"
    fi
    
    log_success "网络诊断完成"
}

# 修复权限
fix_permissions() {
    log_info "尝试修复权限..."
    
    # 修复日志目录权限
    if [[ -d "$IPV6WGM_LOG_DIR" ]]; then
        chmod 755 "$IPV6WGM_LOG_DIR" 2>/dev/null || true
        chown -R "$IPV6WGM_USER:$IPV6WGM_USER" "$IPV6WGM_LOG_DIR" 2>/dev/null || true
    fi
    
    # 修复配置目录权限
    if [[ -d "$IPV6WGM_CONFIG_DIR" ]]; then
        chmod 755 "$IPV6WGM_CONFIG_DIR" 2>/dev/null || true
        chown -R "$IPV6WGM_USER:$IPV6WGM_USER" "$IPV6WGM_CONFIG_DIR" 2>/dev/null || true
    fi
    
    # 修复脚本执行权限
    find "$IPV6WGM_SCRIPT_DIR" -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
    
    log_success "权限修复完成"
}

# 安装缺失依赖
install_missing_dependencies() {
    log_info "尝试安装缺失依赖..."
    
    local missing_deps=()
    
    # 检查必要命令
    local required_commands=("curl" "wget" "git" "jq" "sqlite3")
    
    for cmd in "${required_commands[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            missing_deps+=("$cmd")
        fi
    done
    
    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log_info "发现缺失依赖: ${missing_deps[*]}"
        
        # 根据系统类型安装依赖
        if command -v apt-get &> /dev/null; then
            # Debian/Ubuntu系统
            for dep in "${missing_deps[@]}"; do
                case "$dep" in
                    "jq")
                        safe_execute "apt-get update && apt-get install -y jq" "安装jq" "true" 60
                        ;;
                    "sqlite3")
                        safe_execute "apt-get update && apt-get install -y sqlite3" "安装sqlite3" "true" 60
                        ;;
                esac
            done
        elif command -v yum &> /dev/null; then
            # CentOS/RHEL系统
            for dep in "${missing_deps[@]}"; do
                case "$dep" in
                    "jq")
                        safe_execute "yum install -y jq" "安装jq" "true" 60
                        ;;
                    "sqlite3")
                        safe_execute "yum install -y sqlite" "安装sqlite3" "true" 60
                        ;;
                esac
            done
        else
            log_warn "无法自动安装依赖，请手动安装: ${missing_deps[*]}"
        fi
    else
        log_success "所有依赖都已安装"
    fi
}

# 重启服务
restart_services() {
    log_info "尝试重启相关服务..."
    
    # 重启WireGuard服务
    if systemctl is-active --quiet wg-quick@wg0; then
        safe_execute "systemctl restart wg-quick@wg0" "重启WireGuard服务" "true" 30
    fi
    
    # 重启BIRD服务
    if systemctl is-active --quiet bird; then
        safe_execute "systemctl restart bird" "重启BIRD服务" "true" 30
    fi
    
    # 重启Nginx服务
    if systemctl is-active --quiet nginx; then
        safe_execute "systemctl restart nginx" "重启Nginx服务" "true" 30
    fi
    
    log_success "服务重启完成"
}

# ================================================================
# 错误统计和报告
# ================================================================

# 错误统计
declare -A IPV6WGM_ERROR_STATS=(
    ["total_errors"]=0
    ["critical_errors"]=0
    ["error_errors"]=0
    ["warning_errors"]=0
    ["info_errors"]=0
)

# 记录错误统计
record_error_stat() {
    local severity="$1"
    
    IPV6WGM_ERROR_STATS["total_errors"]=$((IPV6WGM_ERROR_STATS["total_errors"] + 1))
    
    case "$severity" in
        "CRITICAL"|"FATAL")
            IPV6WGM_ERROR_STATS["critical_errors"]=$((IPV6WGM_ERROR_STATS["critical_errors"] + 1))
            ;;
        "ERROR")
            IPV6WGM_ERROR_STATS["error_errors"]=$((IPV6WGM_ERROR_STATS["error_errors"] + 1))
            ;;
        "WARNING")
            IPV6WGM_ERROR_STATS["warning_errors"]=$((IPV6WGM_ERROR_STATS["warning_errors"] + 1))
            ;;
        *)
            IPV6WGM_ERROR_STATS["info_errors"]=$((IPV6WGM_ERROR_STATS["info_errors"] + 1))
            ;;
    esac
}

# 生成错误报告
generate_error_report() {
    local report_file="${IPV6WGM_LOG_DIR}/error_report_$(date +%Y%m%d_%H%M%S).html"
    
    cat > "$report_file" << EOF
<!DOCTYPE html>
<html>
<head>
    <title>IPv6 WireGuard Manager 错误报告</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { background-color: #f0f0f0; padding: 20px; border-radius: 5px; }
        .summary { background-color: #fff3cd; padding: 15px; border-radius: 5px; margin: 20px 0; }
        .error-item { margin: 10px 0; padding: 10px; border-left: 4px solid #ccc; }
        .critical { border-left-color: #dc3545; background-color: #f8d7da; }
        .error { border-left-color: #fd7e14; background-color: #ffeaa7; }
        .warning { border-left-color: #ffc107; background-color: #fff3cd; }
        .info { border-left-color: #17a2b8; background-color: #d1ecf1; }
    </style>
</head>
<body>
    <div class="header">
        <h1>IPv6 WireGuard Manager 错误报告</h1>
        <p>生成时间: $(date)</p>
    </div>
    
    <div class="summary">
        <h2>错误统计</h2>
        <p><strong>总错误数:</strong> ${IPV6WGM_ERROR_STATS["total_errors"]}</p>
        <p><strong>严重错误:</strong> ${IPV6WGM_ERROR_STATS["critical_errors"]}</p>
        <p><strong>错误:</strong> ${IPV6WGM_ERROR_STATS["error_errors"]}</p>
        <p><strong>警告:</strong> ${IPV6WGM_ERROR_STATS["warning_errors"]}</p>
        <p><strong>信息:</strong> ${IPV6WGM_ERROR_STATS["info_errors"]}</p>
    </div>
</body>
</html>
EOF
    
    log_success "错误报告已生成: $report_file"
}

# ================================================================
# 导出函数
# ================================================================

export -f handle_error execute_error_recovery safe_execute validate_command_result
export -f run_network_diagnosis fix_permissions install_missing_dependencies restart_services
export -f record_error_stat generate_error_report
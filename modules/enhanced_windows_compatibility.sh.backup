#!/bin/bash

# 增强的Windows兼容性模块
# 提供完整的Windows环境检测、适配和兼容性处理

# 导入公共函数库
if [[ -f "$(dirname "${BASH_SOURCE[0]}")/common_functions.sh" ]]; then
    source "$(dirname "${BASH_SOURCE[0]}")/common_functions.sh"
fi

# 定义日志函数（如果未定义）
log_info() {
    echo "[INFO] $*"
}

log_warn() {
    echo "[WARN] $*"
}

log_error() {
    echo "[ERROR] $*"
}

log_success() {
    echo "[SUCCESS] $*"
}

# ================================================================
# Windows环境检测和适配
# ================================================================

# 检测Windows环境类型
detect_windows_environment() {
    local env_type="unknown"
    
    # 检测WSL环境
    if [[ -n "${WSL_DISTRO_NAME:-}" ]] || [[ -n "${WSLENV:-}" ]] || \
       ([[ -f /proc/version ]] && grep -qi microsoft /proc/version); then
        env_type="wsl"
        log_info "检测到WSL环境: ${WSL_DISTRO_NAME:-unknown}"
    # 检测MSYS2环境
    elif [[ "$OSTYPE" == "msys" ]] || [[ "$MSYSTEM" == "MSYS" ]]; then
        env_type="msys"
        log_info "检测到MSYS2环境"
    # 检测Cygwin环境
    elif [[ "$OSTYPE" == "cygwin" ]]; then
        env_type="cygwin"
        log_info "检测到Cygwin环境"
    # 检测Git Bash环境
    elif [[ "$OSTYPE" == "msys" ]] && [[ "$MSYSTEM" == "MINGW64" ]]; then
        env_type="gitbash"
        log_info "检测到Git Bash环境"
    # 检测PowerShell环境
    elif [[ -n "${PSModulePath:-}" ]] && [[ "$OS" == "Windows_NT" ]]; then
        env_type="powershell"
        log_info "检测到PowerShell环境"
    fi
    
    export IPV6WGM_WINDOWS_ENV_TYPE="$env_type"
    export IPV6WGM_WINDOWS_ENV=true
    
    return 0
}

# 路径转换函数
convert_path_for_windows() {
    local path="$1"
    local target_type="${2:-native}"
    
    case "$IPV6WGM_WINDOWS_ENV_TYPE" in
        "wsl")
            # WSL中保持Linux路径格式
            echo "$path"
            ;;
        "msys"|"cygwin"|"gitbash")
            # 转换为Windows路径格式
            if command -v cygpath >/dev/null 2>&1; then
                case "$target_type" in
                    "windows") cygpath -w "$path" ;;
                    "unix") cygpath -u "$path" ;;
                    *) cygpath "$path" ;;
                esac
            else
                # 手动转换路径分隔符
                echo "$path" | sed 's|/|\\|g'
            fi
            ;;
        "powershell")
            # PowerShell中转换为Windows路径
            echo "$path" | sed 's|/|\\|g'
            ;;
        *)
            echo "$path"
            ;;
    esac
}

# 创建目录（Windows兼容）
create_directory_windows() {
    local dir_path="$1"
    local permissions="${2:-755}"
    
    # 转换路径
    local windows_path=$(convert_path_for_windows "$dir_path")
    
    case "$IPV6WGM_WINDOWS_ENV_TYPE" in
        "wsl")
            # WSL中使用Linux命令
            if ! mkdir -p "$dir_path" 2>/dev/null; then
                log_warn "无法创建目录: $dir_path"
                return 1
            fi
            # 设置权限（如果支持）
            if command -v chmod >/dev/null 2>&1; then
                chmod "$permissions" "$dir_path" 2>/dev/null || true
            fi
            ;;
        "msys"|"cygwin"|"gitbash")
            # MSYS/Cygwin中使用mkdir
            if ! mkdir -p "$dir_path" 2>/dev/null; then
                log_warn "无法创建目录: $dir_path"
                return 1
            fi
            ;;
        "powershell")
            # PowerShell中使用New-Item
            if command -v powershell >/dev/null 2>&1; then
                powershell -Command "New-Item -ItemType Directory -Path '$windows_path' -Force" 2>/dev/null || {
                    log_warn "无法创建目录: $windows_path"
                    return 1
                }
            else
                log_warn "PowerShell不可用，无法创建目录"
                return 1
            fi
            ;;
        *)
            # 默认使用mkdir
            mkdir -p "$dir_path" 2>/dev/null || {
                log_warn "无法创建目录: $dir_path"
                return 1
            }
            ;;
    esac
    
    log_info "目录创建成功: $dir_path"
    return 0
}

# 设置文件权限（Windows兼容）
set_file_permissions_windows() {
    local file_path="$1"
    local permissions="$2"
    
    case "$IPV6WGM_WINDOWS_ENV_TYPE" in
        "wsl")
            # WSL中可以使用chmod
            if command -v chmod >/dev/null 2>&1; then
                chmod "$permissions" "$file_path" 2>/dev/null || {
                    log_warn "无法设置文件权限: $file_path"
                    return 1
                }
            fi
            ;;
        "msys"|"cygwin"|"gitbash")
            # MSYS/Cygwin中可以使用chmod
            if command -v chmod >/dev/null 2>&1; then
                chmod "$permissions" "$file_path" 2>/dev/null || {
                    log_warn "无法设置文件权限: $file_path"
                    return 1
                }
            fi
            ;;
        "powershell")
            # PowerShell中设置文件属性
            if command -v powershell >/dev/null 2>&1; then
                local windows_path=$(convert_path_for_windows "$file_path")
                case "$permissions" in
                    "600")
                        powershell -Command "Set-ItemProperty -Path '$windows_path' -Name IsReadOnly -Value \$false" 2>/dev/null
                        ;;
                    "644")
                        powershell -Command "Set-ItemProperty -Path '$windows_path' -Name IsReadOnly -Value \$false" 2>/dev/null
                        ;;
                esac
            fi
            ;;
        *)
            # 默认尝试chmod
            if command -v chmod >/dev/null 2>&1; then
                chmod "$permissions" "$file_path" 2>/dev/null || true
            fi
            ;;
    esac
    
    return 0
}

# 检查命令是否可用（Windows兼容）
check_command_available_windows() {
    local cmd="$1"
    
    case "$IPV6WGM_WINDOWS_ENV_TYPE" in
        "wsl")
            # WSL中检查Linux命令
            command -v "$cmd" >/dev/null 2>&1
            ;;
        "msys"|"cygwin"|"gitbash")
            # MSYS/Cygwin中检查命令
            command -v "$cmd" >/dev/null 2>&1
            ;;
        "powershell")
            # PowerShell中检查命令
            if [[ "$cmd" == "wg" ]]; then
                # 检查WireGuard是否安装
                command -v wg >/dev/null 2>&1 || {
                    # 检查Windows版本的WireGuard
                    [[ -f "C:\\Program Files\\WireGuard\\wireguard.exe" ]] 2>/dev/null
                }
            else
                command -v "$cmd" >/dev/null 2>&1
            fi
            ;;
        *)
            command -v "$cmd" >/dev/null 2>&1
            ;;
    esac
}

# 获取临时目录（Windows兼容）
get_temp_dir_windows() {
    case "$IPV6WGM_WINDOWS_ENV_TYPE" in
        "wsl")
            echo "/tmp"
            ;;
        "msys"|"cygwin"|"gitbash")
            echo "/tmp"
            ;;
        "powershell")
            # PowerShell中获取Windows临时目录
            if command -v powershell >/dev/null 2>&1; then
                powershell -Command "[System.IO.Path]::GetTempPath()" 2>/dev/null | tr -d '\r\n'
            else
                echo "/tmp"
            fi
            ;;
        *)
            echo "/tmp"
            ;;
    esac
}

# 运行Windows兼容性测试
run_windows_compatibility_test() {
    log_info "运行Windows兼容性测试..."
    
    # 检测Windows环境
    detect_windows_environment
    
    local test_results=()
    local passed=0
    local failed=0
    
    # 测试路径转换
    local test_path="/tmp/test/path"
    local converted_path=$(convert_path_for_windows "$test_path")
    if [[ -n "$converted_path" ]]; then
        test_results+=("✓ 路径转换功能正常")
        ((passed++))
    else
        test_results+=("✗ 路径转换功能失败")
        ((failed++))
    fi
    
    # 测试目录创建
    local test_dir="/tmp/ipv6-wireguard-test-$(date +%s)"
    if create_directory_windows "$test_dir"; then
        test_results+=("✓ 目录创建功能正常")
        ((passed++))
        # 清理测试目录
        rm -rf "$test_dir" 2>/dev/null || true
    else
        test_results+=("✗ 目录创建功能失败")
        ((failed++))
    fi
    
    # 测试命令检查
    if check_command_available_windows "bash"; then
        test_results+=("✓ 命令检查功能正常")
        ((passed++))
    else
        test_results+=("✗ 命令检查功能失败")
        ((failed++))
    fi
    
    # 测试临时目录获取
    local temp_dir=$(get_temp_dir_windows)
    if [[ -n "$temp_dir" ]]; then
        test_results+=("✓ 临时目录获取功能正常")
        ((passed++))
    else
        test_results+=("✗ 临时目录获取功能失败")
        ((failed++))
    fi
    
    # 显示测试结果
    echo "Windows兼容性测试结果:"
    for result in "${test_results[@]}"; do
        echo "  $result"
    done
    
    echo "总计: $passed 通过, $failed 失败"
    
    if [[ $failed -eq 0 ]]; then
        log_success "Windows兼容性测试全部通过"
        return 0
    else
        log_warn "Windows兼容性测试有 $failed 个失败"
        return 1
    fi
}

# 初始化Windows兼容性
init_windows_compatibility() {
    log_info "初始化Windows兼容性模块..."
    
    # 检测Windows环境
    detect_windows_environment
    
    # 设置环境变量
    export IPV6WGM_TEMP_DIR=$(get_temp_dir_windows)
    export IPV6WGM_WINDOWS_COMPAT=true
    
    # 创建必要的目录
    create_directory_windows "$IPV6WGM_TEMP_DIR/ipv6-wireguard-test" 2>/dev/null || true
    
    log_info "Windows兼容性模块初始化完成"
    return 0
}

# 主函数
main() {
    case "${1:-}" in
        "test")
            run_windows_compatibility_test
            ;;
        "init")
            init_windows_compatibility
            ;;
        *)
            log_info "Windows兼容性模块已加载"
            init_windows_compatibility
            ;;
    esac
}

# 如果直接运行此脚本
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
